# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Bitcoin Core
BITCOIN_RPC_HOST=http://localhost
BITCOIN_RPC_PORT=18443
BITCOIN_RPC_USER=bitcoinrpc
BITCOIN_RPC_PASSWORD=changeme
BITCOIN_NETWORK=regtest

# LND Configuration
LND_GRPC_HOST=localhost:10009
LND_REST_URL=https://localhost:8080
LND_TLS_CERT_PATH=./docker/lnd/tls.cert
LND_MACAROON_PATH=./docker/lnd/data/chain/bitcoin/regtest/admin.macaroon

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/anchor_service

# Redis
REDIS_URL=redis://localhost:6380

# Service Configuration
MIN_FEE_RATE=1
MAX_FEE_RATE=1000
RESERVE_AMOUNT=100000000
SERVICE_FEE_PERCENTAGE=1