# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Bitcoin Core - local development (regtest)
BITCOIN_RPC_HOST=http://localhost
BITCOIN_RPC_PORT=18443
BITCOIN_RPC_USER=bitcoinrpc
BITCOIN_RPC_PASSWORD=changeme
BITCOIN_NETWORK=regtest

# Production override example (Render + mainnet via mempool.space)
# BITCOIN_NETWORK=mainnet
# BITCOIN_BACKEND=mempool
# MEMPOOL_API_BASE_URL=https://mempool.space/api

# alternative: your own Bitcoin Core node instead of mempool.space
# BITCOIN_RPC_HOST=https://your-mainnet-bitcoin-node
# BITCOIN_RPC_PORT=8332
# BITCOIN_RPC_USER=youruser
# BITCOIN_RPC_PASSWORD=yourpassword

# LND Configuration - local development (regtest)
LND_GRPC_HOST=localhost:10009
LND_REST_URL=https://localhost:8080
LND_TLS_CERT_PATH=./docker/lnd/tls.cert
LND_MACAROON_PATH=./docker/lnd/data/chain/bitcoin/regtest/admin.macaroon
LND_RPC_TIMEOUT_MS=10000

# Production override example (Render + Voltage mainnet/your own mainnet node)
# LND_GRPC_HOST=your-node-name.m.voltageapp.io:10009
# LND_TLS_CERT_BASE64=base64-encoded-tls-cert
# LND_MACAROON_BASE64=base64-encoded-admin-macaroon

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/anchor_service

# Redis
REDIS_URL=redis://localhost:6380

# Service Configuration
MIN_FEE_RATE=1
MAX_FEE_RATE=1000
RESERVE_AMOUNT=100000000
SERVICE_FEE_PERCENTAGE=1